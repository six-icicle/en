# Apple notarization credentials for `npm run release`.
# Copy this file to `.env.release` (gitignored) and fill in the real values.

# Apple ID email (the account that owns the developer enrollment)
APPLE_ID="subscriptions.austin@gmail.com"

# 10-char team ID from `security find-identity -v -p codesigning`
APPLE_TEAM_ID="5ASLTT5NUW"

# App-specific password from https://account.apple.com → Sign-In and Security
# Format: xxxx-xxxx-xxxx-xxxx
APPLE_PASSWORD=""
